# Copy to .env and fill in your key. .env is gitignored, never commit real secrets.
# Put your REAL key in .env, NOT here. This file is a committed template.
OPENAI_API_KEY=sk-your-key-here

# Optional model overrides (defaults shown). "Right model for the job":
# strong model for planning/reviewing/judging, cheap model for execution.
PLANNER_MODEL=gpt-4o
EXECUTOR_MODEL=gpt-4o-mini
REVIEWER_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o

# Optional: turn off the built-in OpenAI trace exporter (custom JSONL still works).
# OPENAI_AGENTS_DISABLE_TRACING=1
